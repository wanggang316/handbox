{
  "chat_methods": {
    "base": {
      "default_supported_parameters": [
        "temperature",
        "top_p",
        "max_tokens",
        "streaming"
      ],
      "additional_parameters": ["turn_count"],
      "parameters": {
        "temperature": {
          "component": "slider",
          "level": "base",
          "step": 0.1,
          "name": "Temperature",
          "show_toggle": true,
          "default": 1,
          "max": 2.0,
          "tip": "Temperature 越高，模型生成的内容越随机，反之则越保守。"
        },
        "top_p": {
          "component": "slider",
          "level": "advance",
          "step": 0.05,
          "name": "Top-p",
          "show_toggle": true,
          "default": 1.0,
          "max": 1.0,
          "tip": "Top-p 越高，模型生成的内容越随机，反之则越保守。"
        },
        "top_k": {
          "component": "slider",
          "level": "advance",
          "step": 1,
          "name": "Top-k",
          "show_toggle": true,
          "tip": "Top-k 越高，模型生成的内容越随机，反之则越保守。"
        },
        "max_tokens": {
          "component": "slider",
          "level": "advance",
          "step": 1,
          "name": "输出最大 Token",
          "show_toggle": true,
          "tip": "输出最大 Token 越高，模型生成的内容越长，反之则越短。"
        },
        "streaming": {
          "component": "switch",
          "level": "advance",
          "name": "流式输出",
          "default": true
        },
        "turn_count": {
          "component": "slider",
          "level": "advance",
          "step": 1,
          "name": "上下文对话轮数",
          "show_toggle": false,
          "default": 10,
          "max": 100,
          "tip": "上下文对话轮数越高，模型生成的内容越长，反之则越短。"
        }
      }
    },
    "completions": {
      "parameters": {
        "reasoning_effort": {
          "component": "reasoning",
          "level": "base",
          "name": "Reasoning",
          "effort_options": {
            "common": ["minimal", "low", "medium", "high"]
          }
        }
      }
    },
    "responses": {
      "parameters": {
        "reasoning": {
          "component": "reasoning",
          "level": "base",
          "name": "Reasoning",
          "effort_options": {
            "common": ["minimal", "low", "medium", "high"],
            "openai/gpt-5-pro": ["high"]
          },
          "summary_options": {
            "common": ["auto", "detailed"],
            "openai/computer-use-preview": ["auto", "concise", "detailed"]
          }
        }
      }
    },
    "google_generate_content": {
      "default_supported_parameters": [
        "temperature",
        "top_p",
        "max_tokens",
        "streaming",
        "thinking"
      ],
      "parameters": {
        "reasoning": {
          "component": "thinking",
          "level": "base",
          "name": "Thinking",
          "tip": "The thinkingBudget parameter guides the model on the number of thinking tokens to use when generating a response. A higher token count generally allows for more detailed reasoning, which can be beneficial for tackling more complex tasks. If latency is more important, use a lower budget or disable thinking by setting thinkingBudget to 0. Setting the thinkingBudget to -1 turns on dynamic thinking, meaning the model will adjust the budget based on the complexity of the request.",
          "budget_configs": [
            {
              "models": ["google/gemini-2.5-pro"],
              "options": {
                "dynamic": -1,
                "range": [128, 32768]
              },
              "default": "dynamic"
            },
            {
              "models": [
                "google/gemini-2.5-flash",
                "google/gemini-2.5-flash-preview"
              ],
              "options": {
                "dynamic": -1,
                "disable": 0,
                "range": [1, 24576]
              },
              "default": "dynamic"
            },
            {
              "models": [
                "google/gemini-2.5-flash-lite",
                "google/gemini-2.5-flash-lite-preview"
              ],
              "options": {
                "dynamic": -1,
                "disable": 0,
                "range": [512, 24576]
              },
              "default": "disable"
            }
          ]
        }
      }
    }
  },
  "providers": [
    {
      "type": "openai",
      "type_name": "OpenAI",
      "default_name": "OpenAI",
      "default_base_url": "https://api.openai.com/v1",
