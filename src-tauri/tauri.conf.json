{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "handbox",
  "version": "0.1.0",
  "identifier": "com.gumpw.handbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "handbox",
        "width": 1200,
        "height": 800,
        "minWidth": 500,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 15,
          "y": 27
        }
      },
      {
        "label": "settings",
        "title": "Settings - handbox",
        "url": "/settings",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "maxWidth": 1200,
        "maxHeight": 800,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false,
        "resizable": true,
        "maximizable": false,
        "minimizable": false,
        "trafficLightPosition": {
          "x": 15,
          "y": 27
        }
      },
      {
        "label": "selection_menu",
        "url": "/selection/menu",
        "width": 320,
        "height": 36,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "selection_content",
        "url": "/selection/content",
        "width": 320,
        "height": 240,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "selection_settings",
        "url": "/selection/settings",
        "width": 150,
        "height": 156,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/lib/internal_artifacts": "internal_artifacts"
    }
  }
}
